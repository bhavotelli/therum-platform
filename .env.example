# Database — Supabase: use pooler (PgBouncer / transaction mode) for the app
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"
# Vercel + Supabase integration: if the integration sets POSTGRES_PRISMA_URL but not DATABASE_URL,
# the app falls back to POSTGRES_PRISMA_URL / POSTGRES_URL (see src/lib/database-url.ts, prisma.config.ts).
# Transaction pooler (port 6543): the app adds ?pgbouncer=true&connection_limit=1 if missing — required for Prisma + Supavisor.
# On Vercel, set DATABASE_URL to the same value as POSTGRES_PRISMA_URL unless you rely on the fallback.

# Direct Postgres URL for Prisma migrations (often port 5432, not the pooler port)
DIRECT_URL="postgresql://..."

# Supabase (project settings → API) — paste real values locally; Vercel integration may set SUPABASE_* / NEXT_PUBLIC_* for you
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Gate cookie signing (required in production). Same as NEXTAUTH_SECRET if you use both.
AUTH_SECRET="generate-a-long-random-string"
# Optional alias — Vercel often sets this; getAuthSecret() accepts either
NEXTAUTH_SECRET="same-as-AUTH_SECRET-optional"

# App
NEXT_PUBLIC_THERUM_BETA_PREVIEW_ONLY="false"
THERUM_BETA_PREVIEW_ONLY="false"
