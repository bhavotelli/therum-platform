# Database — Supabase: use pooler (PgBouncer / transaction mode) for the app
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"
# Vercel: resolution order is POSTGRES_PRISMA_URL, DATABASE_PRISMA_DATABASE_URL, then DATABASE_URL, …
# If you linked Supabase on Vercel, prefer the integration’s POSTGRES_PRISMA_URL; delete a stale DATABASE_URL
# that points at another project or the app will connect to the wrong DB.
# Transaction pooler (port 6543): see src/lib/database-url.ts for pgbouncer params.

# Optional: direct Postgres URL (e.g. supabase db push, SQL tools). Not required for Next.js if you only use Supabase JS + service role.
DIRECT_URL="postgresql://..."

# Supabase (project settings → API) — paste real values locally; Vercel integration may set SUPABASE_* / NEXT_PUBLIC_* for you
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"

# Gate cookie signing (required in production). Same as NEXTAUTH_SECRET if you use both.
AUTH_SECRET="generate-a-long-random-string"
# Optional alias — Vercel often sets this; getAuthSecret() accepts either
NEXTAUTH_SECRET="same-as-AUTH_SECRET-optional"

# Xero — register an app at developer.xero.com and set these in Vercel (Production + Preview as needed).
# Mark secrets Sensitive in Vercel. Per-agency tokens are stored in Agency rows after OAuth, not here.
# XERO_REDIRECT_URI must exactly match a redirect URL in the Xero app (often https://YOUR_DOMAIN/api/xero/callback).
# Preview deployments may use a second redirect URI on the same app or a separate Xero "development" app.
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"
XERO_SCOPES="openid profile email accounting.transactions accounting.settings accounting.contacts offline_access"
# Webhook signing key (intent to receive). Optional alias: XERO_WEBHOOK_SIGNING_KEY
XERO_WEBHOOK_KEY=""
# Local only: allow webhook verification without key (see src/app/api/webhooks/xero/route.ts)
# XERO_WEBHOOK_ALLOW_INSECURE_DEV="true"

# App
NEXT_PUBLIC_THERUM_BETA_PREVIEW_ONLY="false"
THERUM_BETA_PREVIEW_ONLY="false"
