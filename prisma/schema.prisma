// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum PlanTier {
  BETA
  SMALL
  MID
  LARGE
}

enum InvoicingModel {
  SELF_BILLING
  ON_BEHALF
}

enum ContactRole {
  PRIMARY
  FINANCE
  OTHER
}

enum DealStage {
  PIPELINE
  NEGOTIATING
  CONTRACTED
  ACTIVE
  IN_BILLING
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  COMPLETE
  INVOICED
  PAID
  PAYOUT_READY
  CANCELLED
}

enum DeliverableStatus {
  PENDING
  SUBMITTED
  APPROVED
}

enum PayoutStatus {
  PENDING
  READY
  PAID
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChaseMethod {
  EMAIL
  PHONE
  IN_PERSON
  OTHER
}

enum ExpenseCategory {
  TRAVEL
  ACCOMMODATION
  PRODUCTION
  USAGE_RIGHTS
  TALENT_FEE_UPLIFT
  OTHER
}

enum ExpenseIncurredBy {
  AGENCY
  TALENT
}

enum ExpenseStatus {
  PENDING
  APPROVED
  INVOICED
  EXCLUDED
}

enum UserRole {
  SUPER_ADMIN
  AGENCY_ADMIN
  AGENT
  FINANCE
  TALENT
}

// -----------------------------------------------------------------------------
// USER & AUTHENTICATION (Incorporated from Square Root Spec)
// -----------------------------------------------------------------------------

model User {
  id            String      @id @default(uuid()) @db.Uuid
  agencyId      String?     @db.Uuid
  talentId      String?     @db.Uuid
  role          UserRole
  active        Boolean     @default(true)
  email         String      @unique
  passwordHash  String?     // Nullable for Magic Link (Talent)
  name          String
  inviteToken   String?
  inviteExpiry  DateTime?
  lastLoginAt   DateTime?
  createdBy     String?     @db.Uuid
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relationships
  agency              Agency?            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  talent              Talent?            @relation(fields: [talentId], references: [id], onDelete: Cascade)
  sessions            Session[]
  resetTokens         ResetToken[]
  chaseNotesLogged    ChaseNote[]
  creditNotesRaised   ManualCreditNote[]
  expensesApproved    DealExpense[]      @relation("ExpenseApprover")
  adminAuditLogs      AdminAuditLog[]    @relation("AdminAuditActor")
  impersonationStarts ImpersonationSession[] @relation("ImpersonationStartedBy")
  impersonationEnds   ImpersonationSession[] @relation("ImpersonationEndedBy")
  previewLogs         PreviewLog[]

  @@index([agencyId])
  @@index([talentId])
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  action      String
  targetType  String
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actorUser   User?    @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId])
  @@index([action])
}

model ImpersonationSession {
  id              String   @id @default(uuid()) @db.Uuid
  adminUserId     String   @db.Uuid
  agencyId        String   @db.Uuid
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  endedByUserId   String?  @db.Uuid

  adminUser       User     @relation("ImpersonationStartedBy", fields: [adminUserId], references: [id], onDelete: Cascade)
  endedByUser     User?    @relation("ImpersonationEndedBy", fields: [endedByUserId], references: [id], onDelete: SetNull)
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([adminUserId, startedAt])
  @@index([agencyId, startedAt])
}

model PreviewLog {
  id          String   @id @default(uuid()) @db.Uuid
  previewedBy String   @db.Uuid
  talentId    String   @db.Uuid
  agencyId    String   @db.Uuid
  startedAt   DateTime @default(now())

  previewer   User     @relation(fields: [previewedBy], references: [id], onDelete: Cascade)
  talent      Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([startedAt])
  @@index([previewedBy, startedAt])
  @@index([agencyId, startedAt])
  @@index([talentId, startedAt])
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// CORE ENTITIES (From Therum Spec)
// -----------------------------------------------------------------------------

model Agency {
  id                String         @id @default(uuid()) @db.Uuid
  name              String
  slug              String         @unique
  active            Boolean        @default(true)
  planTier          PlanTier       @default(BETA)
  xeroTenantId      String?
  xeroTokens        String?        // Encrypted JSON
  stripeAccountId   String?
  commissionDefault Decimal        @db.Decimal(5, 2)
  invoicingModel    InvoicingModel
  vatRegistered     Boolean        @default(false)
  vatNumber         String?
  xeroAccountCodes  Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relationships
  users             User[]
  clients           Client[]
  clientContacts    ClientContact[]
  talents           Talent[]
  deals             Deal[]
  chaseNotes        ChaseNote[]
  manualCreditNotes ManualCreditNote[]
  dealExpenses      DealExpense[]
  impersonationSessions ImpersonationSession[]
  previewLogs       PreviewLog[]
}

model Client {
  id               String   @id @default(uuid()) @db.Uuid
  agencyId         String   @db.Uuid
  name             String
  paymentTermsDays Int      @default(30)
  xeroContactId    String?
  vatNumber        String?
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relationships
  agency           Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  contacts         ClientContact[]
  deals            Deal[]

  @@index([agencyId])
}

model ClientContact {
  id            String      @id @default(uuid()) @db.Uuid
  clientId      String      @db.Uuid
  agencyId      String      @db.Uuid
  name          String
  email         String
  role          ContactRole @default(OTHER)
  phone         String?
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relationships
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agency        Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Talent {
  id              String   @id @default(uuid()) @db.Uuid
  agencyId        String   @db.Uuid
  name            String
  email           String
  commissionRate  Decimal  @db.Decimal(5, 2)
  vatRegistered   Boolean  @default(false)
  vatNumber       String?
  xeroContactId   String?
  stripeAccountId String?
  portalEnabled   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  deals           Deal[]
  users           User[]
  previewLogs     PreviewLog[]

  @@index([agencyId])
}

model Deal {
  id               String    @id @default(uuid()) @db.Uuid
  agencyId         String    @db.Uuid
  clientId         String    @db.Uuid
  talentId         String    @db.Uuid
  title            String
  stage            DealStage @default(PIPELINE)
  probability      Int       @default(10)
  commissionRate   Decimal   @db.Decimal(5, 2)
  paymentTermsDays Int?
  currency         String    @default("GBP")
  contractRef      String?
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  agency           Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  talent           Talent        @relation(fields: [talentId], references: [id], onDelete: Restrict)
  milestones       Milestone[]
  expenses         DealExpense[]

  @@index([agencyId])
}

model Milestone {
  id                           String          @id @default(uuid()) @db.Uuid
  dealId                       String          @db.Uuid
  description                  String
  grossAmount                  Decimal         @db.Decimal(12, 2)
  invoiceDate                  DateTime        @db.Date
  deliveryDueDate              DateTime?       @db.Date
  status                       MilestoneStatus @default(PENDING)
  completedAt                  DateTime?
  payoutStatus                 PayoutStatus    @default(PENDING)
  payoutDate                   DateTime?       @db.Date
  
  // Credit Note Replacements
  cancelledByTripletId         String?         @db.Uuid
  replacedCancelledMilestoneId String?         @unique @db.Uuid

  createdAt                    DateTime        @default(now())
  updatedAt                    DateTime        @updatedAt

  // Relationships
  deal                         Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  invoiceTriplet               InvoiceTriplet?
  deliverables                 Deliverable[]
  expenses                     DealExpense[]
  replacedMilestone            Milestone?        @relation("ReplacementMilestone", fields: [replacedCancelledMilestoneId], references: [id])
  replacementFor               Milestone?        @relation("ReplacementMilestone")
  manualCreditNote             ManualCreditNote? @relation("CreditNoteReplacement")

  @@index([dealId])
}

model Deliverable {
  id          String            @id @default(uuid()) @db.Uuid
  milestoneId String            @db.Uuid
  title       String
  dueDate     DateTime?         @db.Date
  status      DeliverableStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relationships
  milestone   Milestone         @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
}

model InvoiceTriplet {
  id                 String         @id @default(uuid()) @db.Uuid
  milestoneId        String         @unique @db.Uuid
  invoicingModel     InvoicingModel

  // SELF_BILLING fields
  invNumber          String?
  sbiNumber          String?

  // ON_BEHALF fields
  obiNumber          String?
  cnNumber           String?
  xeroObiId          String?
  xeroCnId           String?

  // Shared fields
  comNumber          String
  grossAmount        Decimal        @db.Decimal(12, 2)
  commissionRate     Decimal        @db.Decimal(5, 2)
  commissionAmount   Decimal        @db.Decimal(12, 2)
  netPayoutAmount    Decimal        @db.Decimal(12, 2)
  invoiceDate        DateTime       @db.Date
  issuedAt           DateTime       @default(now())
  invDueDateDays     Int
  approvalStatus     ApprovalStatus @default(PENDING)
  recipientContactName  String?
  recipientContactEmail String?
  recipientContactRole  ContactRole?
  poNumber              String?
  invoiceNarrative      String?         @db.Text
  invoiceAddress        String?         @db.Text
  
  // Xero IDs
  xeroInvId          String?
  xeroSbiId          String?
  xeroComId          String?
  
  invPaidAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Relationships
  milestone          Milestone          @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  chaseNotes         ChaseNote[]
  manualCreditNotes  ManualCreditNote[]
  invoicedExpenses   DealExpense[]
}

model ChaseNote {
  id               String      @id @default(uuid()) @db.Uuid
  invoiceTripletId String      @db.Uuid
  agencyId         String      @db.Uuid
  createdByUserId  String      @db.Uuid
  contactedName    String
  contactedEmail   String
  method           ChaseMethod
  note             String      @db.Text
  nextChaseDate    DateTime?   @db.Date
  createdAt        DateTime    @default(now())

  // Relationships
  invoiceTriplet   InvoiceTriplet @relation(fields: [invoiceTripletId], references: [id], onDelete: Cascade)
  agency           Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser    User           @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([invoiceTripletId])
}

model ManualCreditNote {
  id                     String   @id @default(uuid()) @db.Uuid
  invoiceTripletId       String   @db.Uuid
  agencyId               String   @db.Uuid
  createdByUserId        String   @db.Uuid
  cnNumber               String
  cnDate                 DateTime @db.Date
  amount                 Decimal  @db.Decimal(12, 2)
  reason                 String   @db.Text
  requiresReplacement    Boolean  @default(false)
  replacementMilestoneId String?  @unique @db.Uuid
  xeroCnId               String?
  createdAt              DateTime @default(now())

  // Relationships
  invoiceTriplet       InvoiceTriplet @relation(fields: [invoiceTripletId], references: [id], onDelete: Cascade)
  agency               Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdByUser        User           @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  replacementMilestone Milestone?     @relation("CreditNoteReplacement", fields: [replacementMilestoneId], references: [id])

  @@index([agencyId])
  @@index([invoiceTripletId])
}

model DealExpense {
  id              String            @id @default(uuid()) @db.Uuid
  agencyId        String            @db.Uuid
  dealId          String            @db.Uuid
  milestoneId     String?           @db.Uuid
  description     String
  category        ExpenseCategory
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("GBP")
  vatApplicable   Boolean           @default(true)
  incurredBy      ExpenseIncurredBy

  // Control flags
  rechargeable    Boolean           @default(false)
  contractSignOff Boolean           @default(false)
  status          ExpenseStatus     @default(PENDING)
  
  approvedById    String?           @db.Uuid
  approvedAt      DateTime?
  receiptUrl      String?
  supplierRef     String?
  notes           String?           @db.Text
  invoiceLineRef  String?
  invoicedOnInvId String?           @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relationships
  agency          Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  deal            Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  milestone       Milestone?      @relation(fields: [milestoneId], references: [id])
  approvedBy      User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  invoicedOnInv   InvoiceTriplet? @relation(fields: [invoicedOnInvId], references: [id])

  @@index([dealId])
}